# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL (usar DATABASE_URL en Render)
DATABASE_URL=postgresql://usuario:password@localhost:5432/ecommerce_db

# JWT - clave secreta para firmar tokens (mínimo 32 caracteres)
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui_32chars

# Stripe - modo test (claves que empiezan por pk_test_ y sk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publicable
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta

# Origen permitido para CORS (mismo origen si frontend está en Express)
FRONTEND_URL=http://localhost:3000
